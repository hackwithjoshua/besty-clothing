rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper — is the request coming from a verified admin?
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Admins collection — a logged-in user can only read their own doc
    match /admins/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false; // only editable from Firebase Console
    }

    // Products — anyone can read, only admin can write
    match /products/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Orders — logged-in users can create + read their own orders
    match /orders/{id} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null &&
                       (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    // Users — each user can read/write their own profile doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
